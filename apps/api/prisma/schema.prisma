generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DISABLED
}

model Organization {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String           @db.VarChar(160)
  slug      String           @unique @db.VarChar(120)
  logo      String?          @db.VarChar(2048)
  timezone  String           @default("UTC") @db.VarChar(80)
  country   String?          @db.VarChar(2)
  currency  String           @default("USD") @db.VarChar(3)
  plan      OrganizationPlan @default(FREE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  users         User[]
  roles         Role[]
  sessions      Session[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
  loginHistory  LoginHistory[]
  projects      Project[]

  @@index([plan])
  @@index([country])
  @@index([deletedAt])
  @@map("organizations")
}

model User {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String     @unique @db.VarChar(320)
  passwordHash        String     @db.VarChar(255)
  firstName           String     @db.VarChar(100)
  lastName            String     @db.VarChar(100)
  avatar              String?    @db.VarChar(2048)
  phone               String?    @db.VarChar(32)
  status              UserStatus @default(INVITED)
  emailVerified       Boolean    @default(false)
  lastLoginAt         DateTime?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  tokenVersion        Int        @default(1)
  mfaEnabled          Boolean    @default(false)
  mfaSecret           String?    @db.VarChar(255)
  organizationId      String     @db.Uuid
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  roles               UserRole[]
  sessions            Session[]
  auditLogs           AuditLog[]
  refreshTokens       RefreshToken[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  loginHistory        LoginHistory[]
  createdProjects     Project[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([status])
  @@index([lockedUntil])
  @@index([tokenVersion])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @db.Uuid
  name           String    @db.VarChar(120)
  description    String?   @db.VarChar(500)
  isSystem       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  users        UserRole[]
  permissions  RolePermission[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([isSystem])
  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String    @unique @db.VarChar(160)
  name        String    @db.VarChar(160)
  description String?   @db.VarChar(500)
  resource    String    @db.VarChar(120)
  action      String    @db.VarChar(80)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  roles RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@index([action])
  @@index([deletedAt])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Session {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @db.Uuid
  organizationId  String    @db.Uuid
  deviceId        String?   @db.VarChar(120)
  ipAddress       String?   @db.Inet
  userAgent       String?   @db.Text
  browser         String?   @db.VarChar(120)
  operatingSystem String?   @db.VarChar(120)
  country         String?   @db.VarChar(2)
  city            String?   @db.VarChar(120)
  lastSeenAt      DateTime?
  mfaVerifiedAt   DateTime?
  expiresAt       DateTime
  revokedAt       DateTime?
  revokedReason   String?   @db.VarChar(255)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([organizationId])
  @@index([deviceId])
  @@index([lastSeenAt])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("sessions")
}

model AuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?  @db.Uuid
  organizationId String?  @db.Uuid
  action         String   @db.VarChar(120)
  resource       String   @db.VarChar(120)
  ipAddress      String?  @db.Inet
  userAgent      String?  @db.Text
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model RefreshToken {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash         String    @unique @db.VarChar(255)
  tokenFamilyId     String    @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentTokenId     String?   @db.Uuid
  replacedByTokenId String?   @unique @db.Uuid
  userId            String    @db.Uuid
  organizationId    String    @db.Uuid
  sessionId         String?   @db.Uuid
  expiresAt         DateTime
  rotatedAt         DateTime?
  revokedAt         DateTime?
  revokedReason     String?   @db.VarChar(255)
  reuseDetectedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  session         Session?       @relation(fields: [sessionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  parentToken     RefreshToken?  @relation("RefreshTokenParent", fields: [parentTokenId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  childTokens     RefreshToken[] @relation("RefreshTokenParent")
  replacedByToken RefreshToken?  @relation("RefreshTokenReplacement", fields: [replacedByTokenId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  replacesToken   RefreshToken?  @relation("RefreshTokenReplacement")

  @@index([userId])
  @@index([organizationId])
  @@index([sessionId])
  @@index([tokenFamilyId])
  @@index([parentTokenId])
  @@index([replacedByTokenId])
  @@index([expiresAt])
  @@index([rotatedAt])
  @@index([revokedAt])
  @@index([reuseDetectedAt])
  @@map("refresh_tokens")
}

model VerificationToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique @db.VarChar(255)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([consumedAt])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique @db.VarChar(255)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([consumedAt])
  @@map("password_reset_tokens")
}

model LoginHistory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?  @db.Uuid
  organizationId  String?  @db.Uuid
  ipAddress       String?  @db.Inet
  userAgent       String?  @db.Text
  browser         String?  @db.VarChar(120)
  operatingSystem String?  @db.VarChar(120)
  country         String?  @db.VarChar(2)
  city            String?  @db.VarChar(120)
  success         Boolean
  createdAt       DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([success])
  @@index([createdAt])
  @@index([ipAddress])
  @@map("login_history")
}

model Project {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @db.Uuid
  name           String        @db.VarChar(160)
  description    String?       @db.Text
  status         ProjectStatus @default(PLANNED)
  startDate      DateTime?
  endDate        DateTime?
  color          String?       @db.VarChar(32)
  archived       Boolean       @default(false)
  createdById    String        @db.Uuid
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([archived])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("projects")
}
