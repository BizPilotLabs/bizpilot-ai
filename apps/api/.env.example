NODE_ENV=development
PORT=4000
HOST=0.0.0.0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bizpilot_ai?schema=public
JWT_SECRET=change-this-secret-in-production
JWT_ISSUER=bizpilot-ai
JWT_AUDIENCE=bizpilot-ai-api
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
SESSION_EXPIRES_IN_DAYS=30
REFRESH_TOKEN_COOKIE_NAME=bizpilot_refresh_token
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_MS=10000